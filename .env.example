# Database (Neon Postgres via Vercel Marketplace)
DATABASE_URL=postgresql://user:password@host/dbname

# Encryption key for OAuth tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
DATABASE_ENCRYPTION_KEY=

# LLM Provider: "gemini" (free, default) or "claude" (production)
LLM_PROVIDER=gemini

# Google Gemini (free tier — 1500 req/day)
GOOGLE_GEMINI_API_KEY=

# Anthropic Claude (production — ~$1-3/month)
ANTHROPIC_API_KEY=

# Slack Bot
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
OWNER_SLACK_USER_ID=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Endpoint secrets
CRON_SECRET=
SETUP_SECRET=
